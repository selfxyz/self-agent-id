    "zk-proof"
  ],
  "author": "Self Protocol",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfxyz/self-agent-id.git",
    "directory": "typescript-sdk"
  },
  "homepage": "https://github.com/selfxyz/self-agent-id#readme",
  "bugs": {
    "url": "https://github.com/selfxyz/self-agent-id/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "ethers": "^6.16.0"
  },
