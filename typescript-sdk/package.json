  "description": "TypeScript SDK for Self Agent ID — agent signing + service verification",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "self-agent": "dist/cli.js",
    "self-agent-cli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:all": "tsc",
    "test": "tsc && node --test dist/**/*.test.js",
