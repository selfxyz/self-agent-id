# ── Server-side secrets (do NOT use NEXT_PUBLIC_ prefix) ─────────────────

# Relayer private key for on-chain demo verification meta-transactions
RELAYER_PRIVATE_KEY=

# Demo agent private keys — per-network (for agent-to-agent demo)
DEMO_AGENT_PRIVATE_KEY_SEPOLIA=
DEMO_AGENT_PRIVATE_KEY_MAINNET=

# Pimlico API key for Account Abstraction (Smart Wallet mode)
# Get one at https://dashboard.pimlico.io
PIMLICO_API_KEY=

# LangChain agent service URL (Cloud Run)
LANGCHAIN_URL=

# ── Client-side config (NEXT_PUBLIC_ prefix) ─────────────────────────────

# ZeroDev project ID for passkey-based smart wallets
# Create at https://dashboard.zerodev.app (chain-agnostic)
NEXT_PUBLIC_ZERODEV_PROJECT_ID=

# WebAuthn Relying Party ID for passkeys (must match the production domain).
# Passkeys registered under one RP ID cannot be used on a different domain.
# Falls back to window.location.hostname if unset.
# NEXT_PUBLIC_PASSKEY_RP_ID=app.ai.self.xyz

# Private RPC URLs (optional — falls back to public Forno endpoints)
# Set these to avoid rate limits under traffic
# NEXT_PUBLIC_RPC_CELO=https://celo-mainnet.infura.io/v3/YOUR_KEY
# NEXT_PUBLIC_RPC_CELO_SEPOLIA=https://celo-sepolia.infura.io/v3/YOUR_KEY

# NOTE: Contract addresses are hardcoded in lib/network.ts.
# Update that file directly on contract redeploy — no env vars needed.

# ── MCP Server (/api/mcp) ────────────────────────────────────────────────

# Encryption key for registration session tokens (AES-256-GCM).
# Generate with: openssl rand -hex 32
# Required for self_register_agent and self_check_registration tools.
SESSION_SECRET=

# Agent private key for MCP tools that require a signing identity
# (self_get_identity, self_sign_request, self_authenticated_fetch, self_deregister_agent).
# INTENTIONALLY UNSET on shared deployments — setting this would let any
# MCP client sign requests as this agent. Only set for private/single-user deployments.
# SELF_AGENT_PRIVATE_KEY=

# Optional: restrict self_authenticated_fetch egress to specific hosts.
# Comma-separated hostnames; supports wildcard subdomain entries like "*.example.com".
# If unset, any public host is allowed.
# MCP_AUTH_FETCH_ALLOWED_HOSTS=api.example.com,*.trusted.example

# By default, self_authenticated_fetch blocks localhost/private-network targets
# (e.g. 127.0.0.1, 10.x.x.x, localhost) to reduce SSRF risk.
# Set to true only in controlled development environments.
# MCP_AUTH_FETCH_ALLOW_PRIVATE_NETWORKS=false

# Replay protection for self_verify_request (enabled by default).
# Set to false only for debugging/compatibility scenarios where duplicate
# signed requests must be re-verified by MCP.
# MCP_VERIFY_REQUEST_REPLAY_PROTECTION=true

# Temporary compatibility toggle for legacy `?token=` session URLs on
# /api/agent/register/status, /api/agent/register/qr, and
# /api/agent/deregister/status. Keep false in production.
# ALLOW_LEGACY_QUERY_SESSION_TOKEN=false

# Custom RPC URL override (defaults to public Celo Forno endpoints from SDK).
# SELF_RPC_URL=
